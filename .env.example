# ──────────────────────────────────────────────
# Aurora Docker Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env

# ── LLM Provider Keys ─────────────────────────
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=

# ── PostgreSQL ─────────────────────────────────
POSTGRES_PASSWORD=aurora_secret

# ── Neo4j ──────────────────────────────────────
NEO4J_PASSWORD=aurora_neo4j
