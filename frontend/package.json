{
  "name": "aurora-frontend",
  "private": true,
  "version": "0.1.0",
  "description": "Aurora Design Desktop Application",
  "author": "Aurora Design Team",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "electron:dev": "concurrently \"vite --port 3000\" \"wait-on http://localhost:3000 && npm run electron:compile && electron .\"",
    "electron:preview": "ELECTRON=true npm run build && npm run electron:compile && electron .",
    "electron:compile": "tsc -p electron/tsconfig.json && mv dist-electron/main.js dist-electron/main.cjs && mv dist-electron/preload.js dist-electron/preload.cjs",
    "electron:build": "ELECTRON=true npm run build && npm run electron:compile && electron-builder",
    "electron:pack": "npm run electron:build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
